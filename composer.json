{
    "name": "jmonitoring/jmonitor",
    "description": "simple php web server monitoring library",
    "keywords": [
        "monitoring", "metrics", "mysql", "apache", "php", "redis", "nginx", "system"
    ],
    "homepage": "https://jmonitor.io/",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Jmonitor\\JmonitorPhp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jmonitor\\JmonitorPhp\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "phpstan": "./vendor/bin/phpstan"
    }
}
